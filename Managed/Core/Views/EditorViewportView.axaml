<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ArisenEditor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ArisenEditor.Views.EditorViewportView"
             x:DataType="viewModels:EditorViewportViewModel">
    
    <Grid Background="Black">
        <Image Source="{Binding ViewportImage}" Stretch="Fill"/>
        
        <!-- Future additions: Gizmo overlays, UI overlays go here! -->
        <!-- Because this is an Image, we don't have airspace clipping issues. -->
    </Grid>
</UserControl>
