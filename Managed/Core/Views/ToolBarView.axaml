<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArisenEditor.Core.Views"
             mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="250"
             Height="36"
             x:DataType="vm:ToolbarViewModel"
             x:Class="ArisenEditor.Core.Views.ToolBarView">
    <Border Classes="MainToolbar">
        <Grid ColumnDefinitions="Auto, *, Auto" Margin="12,0">
            <!-- Transform Tools -->
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="ToolbarButton" Command="{Binding NavCommand}">
                    <Path Stretch="Uniform" Fill="#94a3b8" Data="M10.5,9H4.5V3H10.5V9M10.5,21H4.5V15H10.5V21M19.5,9H13.5V3H19.5V9M19.5,21H13.5V15H19.5V21" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button Classes="ToolbarButton" Command="{Binding MoveCommand}" Background="{DynamicResource ArisenPrimaryBrush}" Opacity="0.1" BorderBrush="{DynamicResource ArisenPrimaryBrush}" BorderThickness="1">
                    <Path Stretch="Uniform" Fill="{DynamicResource ArisenPrimaryBrush}" Data="M10,21V19H6.41L10.91,14.5L9.5,13.09L5,17.59V14H3V21H10M14.5,10.91L19,6.41V10H21V3H14V5H17.59L13.09,9.5L14.5,10.91Z" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button Classes="ToolbarButton" Command="{Binding RotateCommand}">
                    <Path Stretch="Uniform" Fill="#94a3b8" Data="M3,3V9H5V5H9V3H3M15,3V5H19V9H21V3H15M3,15V21H9V19H5V15H3M21,15V21H15V19H19V15H21Z" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Separator Width="1" Height="20" Background="{DynamicResource ArisenBorderDarkBrush}" Margin="8,0"/>
                <Button Classes="ToolbarButton" Command="{Binding SelectCommand}">
                     <Path Stretch="Uniform" Fill="#94a3b8" Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button Classes="ToolbarButton" Command="{Binding PhysicsCommand}">
                     <Path Stretch="Uniform" Fill="#94a3b8" Data="M4,15V9H8V4.16L12,1.16L16,4.16V9H20V15H16V20.84L12,23.84L8,20.84V15H4M10,15V19.68L12,21.18L14,19.68V15H10M10,9V13H14V9H10M10,5.66V7H14V5.66L12,4.16L10,5.66Z" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </StackPanel>

            <!-- Transport Controls (Play/Pause/Stop) -->
            <Border Grid.Column="1" HorizontalAlignment="Center" Background="#181e2a" BorderBrush="{DynamicResource ArisenBorderDarkBrush}" BorderThickness="1" CornerRadius="8" Height="28">
                <StackPanel Orientation="Horizontal" Spacing="2" Margin="2">
                    <Button Classes="ToolbarButton" Command="{Binding PlayCommand}">
                        <Path Stretch="Uniform" Fill="#22c55e" Data="M8,5.14V19.14L19,12.14L8,5.14Z" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button Classes="ToolbarButton" Command="{Binding PauseCommand}">
                        <Path Stretch="Uniform" Fill="#3b82f6" Data="M14,19H18V5H14M6,19H10V5H6V19Z" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button Classes="ToolbarButton" Command="{Binding StopCommand}">
                        <Path Stretch="Uniform" Fill="#ef4444" Data="M18,18H6V6H18V18Z" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Layers and Build -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <Border Background="{DynamicResource ArisenPanelDarkBrush}" BorderBrush="{DynamicResource ArisenBorderDarkBrush}" BorderThickness="1" CornerRadius="4" Padding="8,2" Height="28">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="LAYERS" Foreground="#64748b" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="Default" FontSize="11" VerticalAlignment="Center"/>
                        <Path Stretch="Uniform" Fill="#64748b" Data="M7,10L12,15L17,10H7Z" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Button Command="{Binding BuildCommand}" Background="{DynamicResource ArisenPrimaryBrush}" Height="28" Padding="12,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Stretch="Uniform" Fill="White" Data="M12,3L1,9L12,15L23,9L12,3M12,18L3,13V15L12,20L21,15V13L12,18Z" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="Build" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
