<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:ArisenEditor.Core.Views"
             xmlns:treevm="using:ArisenEditor.ViewModels"
             xmlns:converts="using:ArisenEditor.Converters"
             xmlns:menus="using:ArisenEditorFramework.UI.Menus"
             xmlns:ui="using:ArisenEditorFramework.UI.Controls"
             x:Class="ArisenEditor.Views.AssetsBrowserView"
             x:DataType="treevm:AssetsBrowserViewModel">

    <UserControl.Resources>
        <converts:TreeViewIconConverter x:Key="IconConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *" Background="#101622">
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#101622" Height="40" BorderBrush="#282e39" BorderThickness="0,0,0,1" Padding="4">
            <DockPanel Margin="4,0">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Content="Import" Padding="10,4" FontSize="11" Background="#181e2a" BorderThickness="1" BorderBrush="#282e39" Foreground="#94a3b8" />
                    <Button Content="Create" Padding="10,4" FontSize="11" Background="#181e2a" BorderThickness="1" BorderBrush="#282e39" Foreground="#94a3b8">
                        <Button.Flyout>
                            <MenuFlyout ItemsSource="{Binding CreateActions}">
                                <MenuFlyout.ItemContainerTheme>
                                    <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="menus:MenuAction">
                                        <Setter Property="Header" Value="{Binding Header}"/>
                                        <Setter Property="Command" Value="{Binding Command}"/>
                                        <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
                                        <Setter Property="ItemsSource" Value="{Binding Children}"/>
                                    </ControlTheme>
                                </MenuFlyout.ItemContainerTheme>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
                <!-- View Mode Controls -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                    <!-- Slider for Icon Size -->
                    <Slider Minimum="32" Maximum="128" Value="{Binding IconSize}" Width="100" VerticalAlignment="Center" />
                </StackPanel>

                <Border Background="#0f172a" CornerRadius="14" BorderBrush="#1e293b" BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <PathIcon Grid.Column="0" Data="{StaticResource SearchIcon}" Width="12" Height="12" Margin="10,0,4,0" Foreground="#64748b"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding AssetsSearchText}" 
                                 Width="180" 
                                 Height="28" 
                                 Watermark="Search assets..." 
                                 VerticalAlignment="Center"
                                 Padding="4,2" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="12"/>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="250, 4, *">
            <!-- Folder Tree -->
            <ui:ArisenTreeView Grid.Column="0" 
                               x:Name="FolderGrid" 
                               ItemsSource="{Binding FolderSource}" 
                               SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                               Background="#181e2a" />

            <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns" />

            <!-- Asset List -->
            <ui:ArisenListView Grid.Column="2" 
                               x:Name="AssetsGrid" 
                               ItemsSource="{Binding AssetsSource}"
                               SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                               IsIconMode="{Binding IsIconMode}"
                               IconSize="{Binding IconSize}"
                               Background="#181e2a"
                               PointerWheelChanged="OnAssetsPointerWheelChanged">
                <ui:ArisenListView.ContextMenu>
                    <ContextMenu ItemsSource="{Binding ContextActions}">
                        <ContextMenu.ItemContainerTheme>
                            <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="menus:MenuAction">
                                <Setter Property="Header" Value="{Binding Header}"/>
                                <Setter Property="Command" Value="{Binding Command}"/>
                                <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
                                <Setter Property="ItemsSource" Value="{Binding Children}"/>
                            </ControlTheme>
                        </ContextMenu.ItemContainerTheme>
                    </ContextMenu>
                </ui:ArisenListView.ContextMenu>
            </ui:ArisenListView>
        </Grid>
    </Grid>

</UserControl>
