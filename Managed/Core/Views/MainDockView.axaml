<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
             xmlns:vm="clr-namespace:ArisenEditor.Core.Views"
             xmlns:view="clr-namespace:ArisenEditor.Core.Views"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="ArisenEditor.Core.Views.MainDockView"
             x:DataType="vm:MainDockViewModel">
    <DockPanel>
        <!-- The entire UI is now defined by the DockControl and registered panels -->
        <Border Padding="0">
             <dock:DockControl Layout="{Binding Layout}" Factory="{Binding Factory}" />
        </Border>
    </DockPanel>
</UserControl>
