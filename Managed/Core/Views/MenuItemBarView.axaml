<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:view="using:ArisenEditor.Core.Views"
             xmlns:Models="using:ArisenEditorFramework.Core.Models"
             mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="200"
             x:Class="ArisenEditor.Core.Views.MenuItemBarView"
             x:DataType="view:MenuItemBarViewModel" x:CompileBindings="False"
             >
    <Menu ItemsSource="{Binding Items}" Name="MainMenu">
        <Menu.Styles>
            <Style Selector="MenuItem" x:DataType="Models:MenuItemModel">
                <Setter Property="Header" Value="{Binding Header}"/>
                <Setter Property="ItemsSource" Value="{Binding Items}"/>
                <Setter Property="Command" Value="{Binding Command}"/>
                <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
            </Style>
        </Menu.Styles>
    </Menu>
</UserControl>
